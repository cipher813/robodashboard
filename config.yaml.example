# RoboDashboard configuration
# Copy to config.yaml and customize. This file is gitignored.

display:
  default_sort: "market_value"
  default_sort_ascending: false
  hide_zero_positions: true

cache:
  price_history_dir: "cache"
  max_age_hours: 24
  info_max_age_hours: 168       # refetch fundamentals weekly

benchmarks:
  - SPY
  - QQQ

# Alpha Engine page — overlays the paper-trading system's research signals and
# predictor predictions onto your real holdings. Reads from S3 using the default
# AWS profile (no new credentials needed). The page degrades gracefully if AWS
# / boto3 are unavailable, so the rest of the dashboard stays portable.
alpha_engine:
  enabled: true
  bucket: alpha-engine-research

# Friendly labels for the account breakdown, keyed by brokerage account number
# (or the raw SnapTrade account name). Unmapped accounts show their raw name.
# Real account numbers are NOT committed — set these in your gitignored
# config.yaml (or, for the hosted dashboard, in SSM /alpha-engine/robodashboard/).
accounts:
  U00000001: "Trad IRA"
  U00000002: "Roth IRA"
  U00000003: "Growth"
  U00000004: "Dividend Anchor"

# US-vs-International exposure (Geographic Exposure chart) is classified by
# company domicile from yfinance's `country` field — so ADRs (RIO, ASML, TSM…)
# count as International despite their US listing. Override per ticker here when
# the automatic classification is wrong or ambiguous — e.g. a US-domiciled fund
# that gives international *exposure* (Franklin International ETF):
domicile_overrides:
  DIVI: "International"

# ── Phase 4 — AI Advisor ─────────────────────────────────────────────────────
# Two-level gating:
#   1. enabled (PROVISIONING): false → the AI Advisor page is never registered and
#      the anthropic SDK is never imported. Commercial v1 ships with this false, for
#      SEC investment-adviser reasons — zero AI footprint.
#   2. default_on (RUNTIME): initial state of the sidebar "AI insights" toggle (only
#      shown when enabled). Flip it live to A/B the dashboard with vs without AI.
# Requires ANTHROPIC_API_KEY in the environment (.env locally, SSM on the box).
ai_advisor:
  enabled: false
  default_on: true
  model: "claude-haiku-4-5"   # cost-conscious default; bump to claude-sonnet-4-6 for a more nuanced read
  posture: "educational"   # educational (commercial-ready framing) | candid (direct, personal)
  max_tokens: 1500

# The advisor compares your portfolio against these stated targets. Uncomment +
# customize. target_allocation values are fractions of your TOTAL portfolio; the
# advisor normalizes us_equity/international to the equity sleeve it can see.
investor_profile:
  strategy: "growth with income"
  risk_tolerance: "moderate"
  time_horizon: "10+ years"
  target_allocation:
    us_equity: 0.60
    international: 0.15
    fixed_income: 0.15
    alternatives: 0.10
  sector_preferences:
    overweight: ["Technology", "Healthcare"]
    avoid: []
  income_target: 25000
  max_single_position: 0.10
  rebalance_frequency: "quarterly"
