# RoboDashboard configuration
# Copy to config.yaml and customize. This file is gitignored.

display:
  default_sort: "market_value"
  default_sort_ascending: false
  hide_zero_positions: true

cache:
  price_history_dir: "cache"
  max_age_hours: 24
  info_max_age_hours: 168       # refetch fundamentals weekly

benchmarks:
  - SPY
  - QQQ

